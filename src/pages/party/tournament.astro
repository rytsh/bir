---
import Layout from "../../layouts/Layout.astro";
import TournamentBracketTool from "../../components/tools/TournamentBracketTool.svelte";
import { getToolByPath } from "../../data/tools";

const tool = getToolByPath("/party/tournament");
---

<Layout title="Tournament Bracket Generator" description={tool?.description} keywords={tool?.keywords} currentPath="/party/tournament">
  <h1 slot="navbar-title">Tournament Bracket</h1>
  <TournamentBracketTool client:load />
</Layout>
