---
import Layout from "../../layouts/Layout.astro";
import UnitConverterTool from "../../components/tools/UnitConverterTool.svelte";
import { getToolByPath } from "../../data/tools";

const tool = getToolByPath("/converter/unit");
---

<Layout title="Unit Converter - Length, Weight, Temperature & More" description={tool?.description} keywords={tool?.keywords} currentPath="/converter/unit">
  <h1 slot="navbar-title">Unit Converter</h1>
  <UnitConverterTool client:load />
</Layout>
