---
import Layout from "../../layouts/Layout.astro";
import MarkdownPreviewTool from "../../components/tools/MarkdownPreviewTool.svelte";
import { getToolByPath } from "../../data/tools";

const tool = getToolByPath("/text/markdown-preview");
---

<Layout title="Markdown Preview - Live Editor with Mermaid & KaTeX" description={tool?.description} keywords={tool?.keywords} currentPath="/text/markdown-preview">
  <h1 slot="navbar-title">Markdown Preview</h1>
  <MarkdownPreviewTool client:load />
</Layout>
