---
import Layout from "../../layouts/Layout.astro";
import LicenseGeneratorTool from "../../components/tools/LicenseGeneratorTool.svelte";
import { getToolByPath } from "../../data/tools";

const tool = getToolByPath("/generators/license");
---

<Layout title="License Generator - Create LICENSE Files for GitHub" description={tool?.description} keywords={tool?.keywords} currentPath="/generators/license">
  <h1 slot="navbar-title">License Generator</h1>
  <LicenseGeneratorTool client:load />
</Layout>
