---
import Layout from "../../layouts/Layout.astro";
import FinancialCalculatorTool from "../../components/tools/FinancialCalculatorTool.svelte";
import { getToolByPath } from "../../data/tools";

const tool = getToolByPath("/math/financial");
---

<Layout title="Financial Calculator - Loan, Compound Interest, ROI, Retirement" description={tool?.description} keywords={tool?.keywords} currentPath="/math/financial">
  <h1 slot="navbar-title">Financial Calculator</h1>
  <FinancialCalculatorTool client:load />
</Layout>
