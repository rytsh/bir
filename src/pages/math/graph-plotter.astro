---
import Layout from "../../layouts/Layout.astro";
import GraphPlotterTool from "../../components/tools/GraphPlotterTool.svelte";
import { getToolByPath } from "../../data/tools";

const tool = getToolByPath("/math/graph-plotter");
---

<Layout title="Graph Plotter - Mathematical Function Plotter" description={tool?.description} keywords={tool?.keywords} currentPath="/math/graph-plotter">
  <h1 slot="navbar-title">Graph Plotter</h1>
  <GraphPlotterTool client:load />
</Layout>
