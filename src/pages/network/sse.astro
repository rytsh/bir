---
import Layout from "../../layouts/Layout.astro";
import SseTesterTool from "../../components/tools/SseTesterTool.svelte";
import { getToolByPath } from "../../data/tools";

const tool = getToolByPath("/network/sse");
---

<Layout title="Server-Sent Events Tester" description={tool?.description} keywords={tool?.keywords} currentPath="/network/sse">
  <h1 slot="navbar-title">Server-Sent Events</h1>
  <SseTesterTool client:load />
</Layout>
