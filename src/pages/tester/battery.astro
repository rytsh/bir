---
import Layout from "../../layouts/Layout.astro";
import BatteryStatusTool from "../../components/tools/BatteryStatusTool.svelte";
import { getToolByPath } from "../../data/tools";

const tool = getToolByPath("/tester/battery");
---

<Layout title="Battery Status - Charge Level, Time Remaining" description={tool?.description} keywords={tool?.keywords} currentPath="/tester/battery">
  <h1 slot="navbar-title">Battery Status</h1>
  <BatteryStatusTool client:load />
</Layout>
