---
import Layout from "../../layouts/Layout.astro";
import SpeakerTesterTool from "../../components/tools/SpeakerTesterTool.svelte";
import { getToolByPath } from "../../data/tools";

const tool = getToolByPath("/tester/speaker");
---

<Layout title="Speaker Tester - Tone Generator & Channel Test" description={tool?.description} keywords={tool?.keywords} currentPath="/tester/speaker">
  <h1 slot="navbar-title">Speaker Tester</h1>
  <SpeakerTesterTool client:load />
</Layout>
