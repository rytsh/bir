---
import Layout from "../../layouts/Layout.astro";
import WebcamTesterTool from "../../components/tools/WebcamTesterTool.svelte";
import { getToolByPath } from "../../data/tools";

const tool = getToolByPath("/tester/webcam");
---

<Layout title="Webcam Tester - Test Camera, Resolutions, and Capabilities" description={tool?.description} keywords={tool?.keywords} currentPath="/tester/webcam">
  <h1 slot="navbar-title">Webcam Tester</h1>
  <WebcamTesterTool client:load />
</Layout>
