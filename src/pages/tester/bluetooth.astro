---
import Layout from "../../layouts/Layout.astro";
import BluetoothTesterTool from "../../components/tools/BluetoothTesterTool.svelte";
import { getToolByPath } from "../../data/tools";

const tool = getToolByPath("/tester/bluetooth");
---

<Layout title="Bluetooth Tester - Scan BLE Devices and Send Custom GATT Commands" description={tool?.description} keywords={tool?.keywords} currentPath="/tester/bluetooth">
  <h1 slot="navbar-title">Bluetooth Tester</h1>
  <BluetoothTesterTool client:load />
</Layout>
