---
import Layout from "../../layouts/Layout.astro";
import ColorVisionTesterTool from "../../components/tools/ColorVisionTesterTool.svelte";
import { getToolByPath } from "../../data/tools";

const tool = getToolByPath("/tester/color-vision");
---

<Layout title="Color Vision Test - Ishihara-style Screening" description={tool?.description} keywords={tool?.keywords} currentPath="/tester/color-vision">
  <h1 slot="navbar-title">Color Vision Test</h1>
  <ColorVisionTesterTool client:load />
</Layout>
