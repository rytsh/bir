---
import Layout from "../../layouts/Layout.astro";
import ClipboardInspectorTool from "../../components/tools/ClipboardInspectorTool.svelte";
import { getToolByPath } from "../../data/tools";

const tool = getToolByPath("/tester/clipboard");
---

<Layout title="Clipboard Inspector - View Clipboard Contents" description={tool?.description} keywords={tool?.keywords} currentPath="/tester/clipboard">
  <h1 slot="navbar-title">Clipboard Inspector</h1>
  <ClipboardInspectorTool client:load />
</Layout>
